                </a>
            </div> -->
        </div>

        <script>
            let title = document.querySelector('.title');
            let help = document.getElementById('help');
            let type = "Downloading Update";
            let dots = 1;
            //let retries = 0;

            let intervalId = setInterval(() => {
                dots = (dots % 3) + 1;
                title.textContent = `${type}${".".repeat(dots)}`;
                //retries++;

                //if (retries > 8 && help.style.visibility == "hidden")
                //    help.style.visibility = "visible";
            }, 500);

            async function update() {
                try {
                    let dRes = await fetch('/update/download');
                    if (!dRes.ok) throw "Download failed";

                    type = "Installing Update";

                    let iRes = await fetch('/update/install');
                    if (!iRes.ok) throw "Install failed";
                } catch (err) {
                    clearInterval(intervalId);
                    title.textContent = err;
                    help.style.visibility = "visible";
                }
            }

            update();
        </script>
    </section>
